				{
					"name": "Add Answer",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data.answers && jsonData.data.answers.length > 0) {",
									"        var lastAnswer = jsonData.data.answers[jsonData.data.answers.length - 1];",
									"        pm.collectionVariables.set('answer_id', lastAnswer.answerId);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"answerText\": \"Binary search works by repeatedly dividing the search interval in half. Here's a step-by-step explanation:\\n\\n1. Start with the middle element\\n2. If the target equals the middle, return the position\\n3. If target is less than middle, search the left half\\n4. If target is greater than middle, search the right half\\n5. Repeat until found or interval is empty\\n\\nTime complexity: O(log n)\",\n    \"metadata\": {\n        \"references\": [\"Introduction to Algorithms - CLRS\", \"Python Documentation\"],\n        \"difficulty\": \"intermediate\",\n        \"estimatedReadTime\": \"5 minutes\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/teacher/answer/{{question_id}}",
							"host": ["{{base_url}}"],
							"path": ["teacher", "answer", "{{question_id}}"]
						},
						"description": "Add an answer to a question. Requires teacher or admin role."
					},
					"response": []
				},
				{
					"name": "Delete Answer",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/teacher/answer/{{answer_id}}?questionId={{question_id}}",
							"host": ["{{base_url}}"],
							"path": ["teacher", "answer", "{{answer_id}}"],
							"query": [
								{
									"key": "questionId",
									"value": "{{question_id}}"
								}
							]
						},
						"description": "Delete your own answer. Teachers can only delete their own answers, admins can delete any."
					},
					"response": []
				}
			]
		},
