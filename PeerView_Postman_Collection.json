		{
			"name": "Student APIs",
			"item": [
				{
					"name": "Post Question (JSON)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('question_id', jsonData.data.questionId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"How to implement binary search in Python?\",\n    \"moduleCode\": \"CS101\",\n    \"questionId\": \"q-001\",\n    \"description\": \"I need help understanding the implementation of binary search algorithm. Can someone explain the logic?\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/student/question",
							"host": ["{{base_url}}"],
							"path": ["student", "question"]
						},
						"description": "Post a question without media. Requires student role."
					},
					"response": []
				},
				{
					"name": "Post Question with Media",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('question_id', jsonData.data.questionId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "title",
									"value": "Understanding Sorting Algorithms",
									"type": "text"
								},
								{
									"key": "moduleCode",
									"value": "CS102",
									"type": "text"
								},
								{
									"key": "questionId",
									"value": "q-002",
									"type": "text"
								},
								{
									"key": "description",
									"value": "Can someone explain quick sort vs merge sort with visual examples?",
									"type": "text"
								},
								{
									"key": "file",
									"type": "file",
									"src": [],
									"description": "Select an image or video file"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/student/question",
							"host": ["{{base_url}}"],
							"path": ["student", "question"]
						},
						"description": "Post a question with media file (image or video)"
					},
					"response": []
				},
